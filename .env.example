# Copy this file to .env and fill in your values
# cp .env.example .env

# ── LLM ──────────────────────────────────────────────
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5:3b
OLLAMA_TEMPERATURE=0.1
OLLAMA_NUM_CTX=4096

# ── Memory ───────────────────────────────────────────
SQLITE_DB_PATH=data/checkpoints.db
DEFAULT_THREAD_ID=session-001
MEMORY_WINDOW_SIZE=20

# ── Observability ────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=text        # text (dev) | json (prod)
METRICS_PORT=8000

# LangSmith tracing (optional — leave blank to disable)
ENABLE_LANGSMITH=false
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=ls__xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LANGSMITH_PROJECT=purpo-culinary

# ── Evals ────────────────────────────────────────────
EVALS_OUTPUT_DIR=evals_results
